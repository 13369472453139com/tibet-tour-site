---
import MainLayout from '@src/layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

// 获取所有旅游线路
const allTours = await getCollection('tours');
const tours = allTours.sort((a, b) => {
  const priceA = a.data.price || 0;
  const priceB = b.data.price || 0;
  return priceA - priceB;
});
---

<MainLayout title="西藏旅游线路" description="精选西藏经典线路，满足不同旅行需求">
  <div class="py-12 bg-gray-50">
    <div class="container mx-auto px-4">
      <h1 class="text-3xl font-bold text-center mb-8">所有线路</h1>
      
      {tours.length === 0 ? (
        <p class="text-center text-gray-500">暂无旅游线路</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {tours.map((tour) => (
            <div class="bg-white rounded-lg shadow overflow-hidden">
              {tour.data.image && (
                <img src={tour.data.image} alt={tour.data.title} class="w-full h-48 object-cover" />
              )}
              <div class="p-4">
                <h3 class="text-xl font-semibold mb-2">{tour.data.title}</h3>
                <p class="text-gray-600 mb-2">{tour.data.description}</p>
                <p class="text-sm text-gray-500">时长：{tour.data.duration || '详询客服'}</p>
                <div class="flex justify-between items-center mt-4">
                  <span class="text-blue-600 font-bold">¥{tour.data.price || 0}起</span>
                  <a href={`/tours/${tour.slug}`} class="text-blue-600 hover:underline">查看详情 →</a>
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</MainLayout>
