---
import MainLayout from '@src/layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

// 获取所有博客文章，按日期倒序排列
const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
---

<MainLayout title="西藏旅行博客" description="旅行故事与实用攻略">
  <div class="py-12 bg-white">
    <div class="container mx-auto px-4">
      <h1 class="text-3xl font-bold text-center mb-8">所有博客</h1>
      
      {posts.length === 0 ? (
        <p class="text-center text-gray-500">暂无博客文章</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <div class="bg-white rounded-lg shadow p-6">
              <h3 class="text-xl font-semibold mb-2">{post.data.title}</h3>
              <p class="text-gray-600 mb-4">{post.data.description}</p>
              <p class="text-sm text-gray-400">{post.data.date?.toDateString?.() || post.data.date}</p>
              <a href={`/blogs/${post.slug}`} class="inline-block mt-4 text-blue-600 hover:underline">阅读更多 →</a>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</MainLayout>
