---
// 纯硬编码西藏线路（不依赖任何数据文件）
export interface TourSectionProps {
  id?: string;
  title?: string;
  description?: string;
}

const {
  id = "packages",
  title = "热门西藏线路",
  description = "精选西藏经典行程，满足不同旅行需求。",
} = Astro.props;

// 硬编码线路数据
const tours = [
  {
    slug: "lhasa-pilgrim",
    data: {
      title: "拉萨朝圣之旅",
      description: "布达拉宫、大昭寺、八廓街，4天3晚深度体验藏地文化",
      pricing: [{ price: 2980 }],
      image: "/img/tour-lhasa.jpg",
    },
  },
  {
    slug: "namtso-lake",
    data: {
      title: "纳木错圣湖之旅",
      description: "世界海拔最高的咸水湖，雪山与湖水相映，2天1晚",
      pricing: [{ price: 1280 }],
      image: "/img/tour-namtso.jpg",
    },
  },
  {
    slug: "everest-basecamp",
    data: {
      title: "珠峰大本营挑战之旅",
      description: "近距离仰望世界之巅，体验极致高原风光，4天3晚",
      pricing: [{ price: 3850 }],
      image: "/img/tour-everest.jpg",
    },
  },
];
---

<section id={id} class="relative py-16 md:py-20 overflow-hidden">
  <div class="max-w-6xl mx-auto px-4">
    <div class="mb-12 text-center">
      <h2 class="text-3xl md:text-4xl font-semibold text-white">{title}</h2>
      {description && <p class="mt-3 text-white/70 max-w-2xl mx-auto">{description}</p>}
    </div>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {tours.map((tour) => (
        <div class="bg-white rounded-lg shadow overflow-hidden">
          {tour.data.image && <img src={tour.data.image} alt={tour.data.title} class="w-full h-48 object-cover" />}
          <div class="p-4">
            <h3 class="text-xl font-semibold mb-2">{tour.data.title}</h3>
            <p class="text-gray-600 mb-4">{tour.data.description}</p>
            <div class="flex justify-between items-center">
              <span class="text-blue-600 font-bold">¥{tour.data.pricing[0].price}起</span>
              <a href={`/tours/${tour.slug}`} class="text-blue-600 hover:underline">查看详情 →</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>