---
// Footer.astro - 西藏旅游页脚（中文版）
const currentYear = new Date().getFullYear();
---

<footer class="relative mb-4 overflow-hidden">
  <div class="relative mx-auto max-w-6xl px-4">
    <div
      class="relative overflow-hidden rounded-3xl bg-slate-900/40 p-10 text-white backdrop-blur"
      style="background-image: url('/img/about-sea.jpg'); background-size: cover; background-position: center;"
    >
      <div class="absolute inset-0 bg-linear-to-t from-black/90 to-indigo-950/85"></div>
      <div class="relative grid grid-cols-1 gap-10 md:grid-cols-4">
        <!-- 关于我们 -->
        <div class="md:col-span-2 md:pe-12">
          <h3 class="mb-4 text-lg font-semibold">关于西藏旅游</h3>
          <p class="leading-relaxed text-white/70">专注西藏深度旅行，专业导游，高原安全保障，带您探秘世界屋脊的壮美与神秘。</p>
        </div>
        <!-- 快速链接 -->
        <div>
          <h3 class="mb-4 text-lg font-semibold">快速链接</h3>
          <ul class="space-y-2 text-white/80">
            <li><a href="/tours" class="transition hover:text-white">旅游线路</a></li>
            <li><a href="/privacy" class="transition hover:text-white">隐私政策</a></li>
            <li><a href="/terms" class="transition hover:text-white">服务条款</a></li>
            <li><a href="/docs" class="transition hover:text-white">旅行文档</a></li>
          </ul>
        </div>
        <!-- 热门目的地 -->
        <div>
          <h3 class="mb-4 text-lg font-semibold">热门目的地</h3>
          <ul class="space-y-2 text-white/80">
            <li>拉萨</li>
            <li>纳木错</li>
            <li>珠峰大本营</li>
            <li>林芝</li>
            <li>日喀则</li>
          </ul>
        </div>
      </div>
      <div class="relative mt-8 w-full py-4">
        <div class="mx-auto max-w-6xl px-4 text-center text-sm text-white">
          <p>© {currentYear} 西藏旅游. 保留所有权利。</p>
        </div>
      </div>
    </div>
  </div>
</footer>