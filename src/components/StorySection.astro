---
import TourCard from "@src/components/TourCard.astro";
import { getCollection } from "astro:content";

export interface TourSectionProps {
  id?: string;
  title: string;
  description?: string;
  maxTours?: number;
}

const {
  id = "packages",
  title = "热门西藏线路",
  description = "精选西藏经典行程，满足不同旅行需求。",
  maxTours = 8,
} = Astro.props as TourSectionProps;

// 尝试从集合中获取线路
let allTours = [];
try {
  allTours = await getCollection("tours");
} catch (e) {
  console.warn("无法获取线路集合，使用硬编码数据");
}

// 硬编码备用数据（当集合为空时使用）
const fallbackTours = [
  {
    slug: "lhasa-pilgrim",
    data: {
      title: "拉萨朝圣之旅",
      description: "布达拉宫、大昭寺、八廓街，4天3晚深度体验藏地文化",
      pricing: [{ price: 2980 }],
      image: "/img/tour-lhasa.jpg",
    },
  },
  {
    slug: "namtso-lake",
    data: {
      title: "纳木错圣湖之旅",
      description: "世界海拔最高的咸水湖，雪山与湖水相映，2天1晚",
      pricing: [{ price: 1280 }],
      image: "/img/tour-namtso.jpg",
    },
  },
  {
    slug: "everest-basecamp",
    data: {
      title: "珠峰大本营挑战之旅",
      description: "近距离仰望世界之巅，体验极致高原风光，4天3晚",
      pricing: [{ price: 3850 }],
      image: "/img/tour-everest.jpg",
    },
  },
];

let visibleTours = allTours.length > 0 ? allTours : fallbackTours;
if (visibleTours.length > maxTours) visibleTours = visibleTours.slice(0, maxTours);
---

<section id={id} class="relative py-16 md:py-20 overflow-hidden">
  <div class="max-w-6xl mx-auto px-4">
    <div class="mb-12 text-center">
      <h2 class="text-3xl md:text-4xl font-semibold text-white">{title}</h2>
      {description && <p class="mt-3 text-white/70 max-w-2xl mx-auto">{description}</p>}
    </div>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {visibleTours.map((tour) => (
        <TourCard tour={tour} />
      ))}
    </div>
  </div>
</section>